# Copy this file to .env.local and fill in the values.
# On Vercel, set the same variables in Project Settings -> Environment Variables.

# --- Server-only (never exposed to the browser) ---

# Active AI provider. Currently only "openai" is implemented.
AI_PROVIDER=openai

# OpenAI API key. SECRET — keep it out of the client and out of git.
OPENAI_API_KEY=sk-...

# Vision-capable model used to read receipts.
OPENAI_MODEL=gpt-4o-mini

# Google OAuth client ID — used server-side to verify the ID token audience.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Comma-separated allowlist of emails permitted to use the app.
ALLOWED_EMAILS=you@example.com,teammate@example.com

# --- Client-facing (VITE_ prefix is exposed to the browser) ---

# Same Google client ID, used by the Sign-In button. Client IDs are public.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
